# RevOps Pro — environment template
# Copy to .env.local and fill in. Validated at boot via packages/config/env.ts.
# Never commit .env or .env.local.

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database (Neon Postgres) ─────────────────────────────────────────────
# DATABASE_URL is the runtime app role (revops_app). It does NOT bypass RLS.
# DATABASE_MIGRATION_URL is the privileged role used by drizzle-kit, seed
# scripts, and the bypassRls() helper. It bypasses RLS.
# On a fresh Neon project, both URLs initially point to neondb_owner; after
# migration 0001 creates the revops_app role, change DATABASE_URL to use it.
# Get from: https://console.neon.tech → revops-pro → Connection details
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
DATABASE_MIGRATION_URL=postgres://user:pass@host/db?sslmode=require
# Password embedded in the revops_app role at migration time. Generate with:
#   openssl rand -hex 24
REVOPS_APP_DB_PASSWORD=

# ─── Auth (Better Auth) ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ─── Inngest ──────────────────────────────────────────────────────────────
# Get from: https://app.inngest.com → Settings → Event Keys / Signing Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Claude (Anthropic) ───────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Realtime (Pusher) ────────────────────────────────────────────────────
# Get from: https://dashboard.pusher.com
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us3
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us3

# ─── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ─── Errors (Sentry) ──────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── LLM Observability (Langfuse) ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Logs / APM (Axiom) ───────────────────────────────────────────────────
AXIOM_TOKEN=
AXIOM_DATASET=revops-pro

# ─── Product Analytics + Flags (PostHog) ──────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── File storage (Cloudflare R2) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=revops-pro
R2_PUBLIC_URL=

# ─── Billing (Stripe) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Encryption ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to encrypt OAuth tokens stored at rest in data_source_connections
TOKEN_ENCRYPTION_KEY=
